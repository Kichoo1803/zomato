{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "framework": null,
  "buildCommand": "npm run build",
  "outputDirectory": "client/dist",
  "routes": [
    {
      "src": "^/api$",
      "methods": ["GET", "POST", "PUT", "PATCH", "DELETE", "OPTIONS", "HEAD"],
      "dest": "/api/index.ts"
    },
    {
      "src": "^/api/(.*)$",
      "methods": ["GET", "POST", "PUT", "PATCH", "DELETE", "OPTIONS", "HEAD"],
      "dest": "/api/[...route].ts"
    },
    {
      "src": "^/(.*)$",
      "check": true
    },
    {
      "src": "^/(.*)$",
      "dest": "/index.html"
    }
  ]
}
