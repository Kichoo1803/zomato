{
  "name": "zomato-luxe-platform",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Production-style Zomato-inspired food delivery monorepo",
  "workspaces": [
    "client",
    "server"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "concurrently -n client,server -c red,cyan \"npm run dev -w client\" \"npm run dev -w server\"",
    "build": "npm run build -w client && npm run build -w server",
    "lint": "npm run lint -w client && npm run lint -w server",
    "db:analyze": "npm run prisma:analyze:sqlite -w server",
    "db:generate": "npm run prisma:generate -w server",
    "db:generate:if-needed": "npm run prisma:generate:if-needed -w server",
    "db:cleanup:generated": "npm run prisma:cleanup:generated -w server",
    "db:push": "npm run prisma:push -w server",
    "db:sync": "npm run db:push",
    "db:migrate": "npm run db:push",
    "db:migrate:deploy": "npm run db:push",
    "db:seed": "npm run prisma:seed -w server",
    "db:repair:demo-users": "npm run prisma:repair:demo-users -w server",
    "db:migrate:operations-manager-role": "npm run prisma:migrate:operations-manager-role -w server",
    "db:migrate:sqlite-to-mongo": "npm run prisma:migrate:sqlite-to-mongo -w server",
    "db:validate:migration": "npm run prisma:validate:sqlite-to-mongo -w server"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
