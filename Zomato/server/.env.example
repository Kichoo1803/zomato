NODE_ENV=development
PORT=4000
HOST=0.0.0.0
CLIENT_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://192.168.x.x:5173
DATABASE_URL=mongodb://127.0.0.1:27018/zomato?replicaSet=rs0
# The checked-in local setup uses a repo-scoped single-node replica set on port 27018.
# If you later reconfigure your machine-wide MongoDB service as a replica set,
# you can switch back to 27017 and keep the same database name.
LEGACY_SQLITE_DATABASE_URL=file:./dev.db
JWT_ACCESS_SECRET=replace-with-a-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-a-long-random-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
COOKIE_DOMAIN=localhost
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@zomatoluxe.local
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
GOOGLE_MAPS_API_KEY=

# Production deployment example:
# CLIENT_URL=https://your-netlify-site.netlify.app
# CORS_ORIGINS=https://your-netlify-site.netlify.app
# DATABASE_URL=mongodb+srv://<user>:<password>@<cluster>/<database>?retryWrites=true&w=majority
# COOKIE_DOMAIN=
