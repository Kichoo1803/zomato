generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  mongoId                 String                 @id @default(auto()) @map("_id") @db.ObjectId
  id                      Int                    @unique @default(0)
  fullName                String                 @map("full_name")
  email                   String                 @unique
  phone                   String?
  passwordHash            String                 @map("password_hash")
  profileImage            String?                @map("profile_image")
  role                    String                 @default("CUSTOMER")
  regionId                Int?                   @map("region_id")
  opsState                String?                @map("ops_state")
  opsDistrict             String?                @map("ops_district")
  opsNotes                String?                @map("ops_notes")
  membershipTier          String                 @default("CLASSIC") @map("membership_tier")
  membershipStatus        String                 @default("ACTIVE") @map("membership_status")
  membershipStartedAt     DateTime?              @map("membership_started_at")
  membershipExpiresAt     DateTime?              @map("membership_expires_at")
  isActive                Boolean                @default(true) @map("is_active")
  emailVerified           Boolean                @default(false) @map("email_verified")
  phoneVerified           Boolean                @default(false) @map("phone_verified")
  walletBalance           Float                  @default(0) @map("wallet_balance")
  lastLoginAt             DateTime?              @map("last_login_at")
  createdAt               DateTime               @default(now()) @map("created_at")
  updatedAt               DateTime               @updatedAt @map("updated_at")
  addresses               Address[]
  carts                   Cart[]
  deliveryProfile         DeliveryPartner?
  favorites               FavoriteRestaurant[]
  notifications           Notification[]
  operationsNotesAuthored OperationsRegionNote[] @relation("OperationsNoteAuthor")
  orders                  Order[]                @relation("CustomerOrders")
  ownedRestaurants        Restaurant[]           @relation("RestaurantOwnerRestaurants")
  approvalRequestsCreated ApprovalRequest[]      @relation("ApprovalRequestRequester")
  approvalRequestsReviewed ApprovalRequest[]     @relation("ApprovalRequestReviewer")
  assignedRegistrationApplications RegistrationApplication[] @relation("RegistrationApplicationAssignee")
  reviewedRegistrationApplications RegistrationApplication[] @relation("RegistrationApplicationReviewer")
  approvedRegistrationApplications RegistrationApplication[] @relation("RegistrationApplicationApprovedUser")
  managedRegions          Region[]               @relation("RegionManager")
  region                  Region?                @relation("RegionUsers", fields: [regionId], references: [id], onDelete: SetNull)
  refreshTokens           RefreshToken[]
  reservations            Reservation[]
  reviews                 Review[]
  savedPaymentMethods     SavedPaymentMethod[]
  statusEvents            OrderStatusEvent[]

  @@index([role])
  @@index([regionId])
  @@index([opsState, opsDistrict])
  @@map("users")
}

model RefreshToken {
  mongoId   String    @id @default(auto()) @map("_id") @db.ObjectId
  id        Int       @unique @default(0)
  userId    Int       @map("user_id")
  tokenHash String    @unique @map("token_hash")
  userAgent String?   @map("user_agent")
  ipAddress String?   @map("ip_address")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model Address {
  mongoId       String   @id @default(auto()) @map("_id") @db.ObjectId
  id            Int      @unique @default(0)
  userId        Int      @map("user_id")
  addressType   String   @default("HOME") @map("address_type")
  title         String?
  recipientName String?  @map("recipient_name")
  contactPhone  String?  @map("contact_phone")
  houseNo       String?  @map("house_no")
  street        String?
  landmark      String?
  area          String?
  city          String
  state         String
  pincode       String
  latitude      Float?
  longitude     Float?
  isDefault     Boolean  @default(false) @map("is_default")
  isServiceable Boolean  @default(true) @map("is_serviceable")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  orders        Order[]
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([city, pincode])
  @@index([latitude, longitude])
  @@map("addresses")
}

model Restaurant {
  mongoId          String                  @id @default(auto()) @map("_id") @db.ObjectId
  id               Int                     @unique @default(0)
  ownerId          Int                     @map("owner_id")
  regionId         Int?                    @map("region_id")
  name             String
  slug             String                  @unique
  description      String?
  email            String?
  phone            String?
  coverImage       String?                 @map("image")
  logoImage        String?                 @map("logo_image")
  licenseNumber    String?                 @map("license_number")
  openingTime      String?                 @map("opening_time")
  closingTime      String?                 @map("closing_time")
  addressLine      String?                 @map("address_line")
  area             String?
  city             String
  state            String
  pincode          String
  latitude         Float?
  longitude        Float?
  avgRating        Float                   @default(0) @map("avg_rating")
  totalReviews     Int                     @default(0) @map("total_reviews")
  costForTwo       Float                   @default(0) @map("cost_for_two")
  avgDeliveryTime  Int                     @default(30) @map("avg_delivery_time")
  preparationTime  Int                     @default(20) @map("preparation_time")
  isVegOnly        Boolean                 @default(false) @map("is_veg_only")
  isActive         Boolean                 @default(true) @map("is_active")
  isFeatured       Boolean                 @default(false) @map("is_featured")
  createdAt        DateTime                @default(now()) @map("created_at")
  updatedAt        DateTime                @updatedAt @map("updated_at")
  carts            Cart[]
  categoryMappings RestaurantCategoryMap[]
  cuisineMappings  RestaurantCuisine[]
  favorites        FavoriteRestaurant[]
  menuCategories   MenuCategory[]
  menuItems        MenuItem[]
  combos           Combo[]
  itemAddons       ItemAddon[]
  offers           RestaurantOffer[]
  operatingHours   RestaurantHour[]
  orders           Order[]
  owner            User                    @relation("RestaurantOwnerRestaurants", fields: [ownerId], references: [id], onDelete: Cascade)
  region           Region?                 @relation("RegionRestaurants", fields: [regionId], references: [id], onDelete: SetNull)
  reservations     Reservation[]
  reviews          Review[]

  @@index([ownerId])
  @@index([regionId, isActive])
  @@index([city, isActive])
  @@index([isVegOnly, avgRating])
  @@index([latitude, longitude])
  @@map("restaurants")
}

model RestaurantCategory {
  mongoId     String                  @id @default(auto()) @map("_id") @db.ObjectId
  id          Int                     @unique @default(0)
  name        String                  @unique
  description String?
  restaurants RestaurantCategoryMap[]

  @@map("restaurant_categories")
}

model RestaurantCategoryMap {
  mongoId      String             @id @default(auto()) @map("_id") @db.ObjectId
  id           Int                @unique @default(0)
  restaurantId Int                @map("restaurant_id")
  categoryId   Int                @map("category_id")
  category     RestaurantCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  restaurant   Restaurant         @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, categoryId])
  @@index([categoryId])
  @@map("restaurant_category_map")
}

model Cuisine {
  mongoId     String              @id @default(auto()) @map("_id") @db.ObjectId
  id          Int                 @unique @default(0)
  name        String              @unique
  restaurants RestaurantCuisine[]

  @@map("cuisines")
}

model RestaurantCuisine {
  mongoId      String     @id @default(auto()) @map("_id") @db.ObjectId
  id           Int        @unique @default(0)
  restaurantId Int        @map("restaurant_id")
  cuisineId    Int        @map("cuisine_id")
  cuisine      Cuisine    @relation(fields: [cuisineId], references: [id], onDelete: Cascade)
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, cuisineId])
  @@index([cuisineId])
  @@map("restaurant_cuisines")
}

model RestaurantHour {
  mongoId      String     @id @default(auto()) @map("_id") @db.ObjectId
  id           Int        @unique @default(0)
  restaurantId Int        @map("restaurant_id")
  dayOfWeek    Int        @map("day_of_week")
  openTime     String?    @map("open_time")
  closeTime    String?    @map("close_time")
  isClosed     Boolean    @default(false) @map("is_closed")
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, dayOfWeek])
  @@map("restaurant_hours")
}

model MenuCategory {
  mongoId      String     @id @default(auto()) @map("_id") @db.ObjectId
  id           Int        @unique @default(0)
  restaurantId Int        @map("restaurant_id")
  name         String
  description  String?
  isActive     Boolean    @default(true) @map("is_active")
  sortOrder    Int        @default(0) @map("sort_order")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  menuItems    MenuItem[]
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, name])
  @@index([restaurantId, sortOrder])
  @@map("menu_categories")
}

model MenuItem {
  mongoId         String       @id @default(auto()) @map("_id") @db.ObjectId
  id              Int          @unique @default(0)
  restaurantId    Int          @map("restaurant_id")
  categoryId      Int          @map("category_id")
  name            String
  description     String?
  image           String?
  price           Float
  discountPrice   Float?       @map("discount_price")
  foodType        String       @map("food_type")
  isAvailable     Boolean      @default(true) @map("is_available")
  isRecommended   Boolean      @default(false) @map("is_recommended")
  preparationTime Int          @default(20) @map("preparation_time")
  calories        Int?
  spiceLevel      Int?         @map("spice_level")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  addons          ItemAddon[]
  cartItems       CartItem[]
  category        MenuCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  comboItems      ComboItem[]
  orderItems      OrderItem[]
  restaurant      Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, name])
  @@index([restaurantId, categoryId])
  @@index([foodType, isAvailable])
  @@map("menu_items")
}

model Combo {
  mongoId      String      @id @default(auto()) @map("_id") @db.ObjectId
  id           Int         @unique @default(0)
  restaurantId Int         @map("restaurant_id")
  name         String
  description  String?
  image        String?
  basePrice    Float       @map("base_price")
  offerPrice   Float?      @map("offer_price")
  categoryTag  String?     @map("category_tag")
  isAvailable  Boolean     @default(true) @map("is_available")
  isActive     Boolean     @default(true) @map("is_active")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  addons       ItemAddon[]
  cartItems    CartItem[]
  items        ComboItem[]
  orderItems   OrderItem[]
  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, name])
  @@index([restaurantId, isActive, isAvailable])
  @@map("combos")
}

model ComboItem {
  mongoId    String   @id @default(auto()) @map("_id") @db.ObjectId
  id         Int      @unique @default(0)
  comboId    Int      @map("combo_id")
  menuItemId Int      @map("menu_item_id")
  quantity   Int      @default(1)
  combo      Combo    @relation(fields: [comboId], references: [id], onDelete: Cascade)
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@unique([comboId, menuItemId])
  @@index([menuItemId])
  @@map("combo_items")
}

model ItemAddon {
  mongoId      String          @id @default(auto()) @map("_id") @db.ObjectId
  id           Int             @unique @default(0)
  restaurantId Int             @map("restaurant_id")
  menuItemId   Int?            @map("menu_item_id")
  comboId      Int?            @map("combo_id")
  name         String
  description  String?
  addonType    String          @default("EXTRA") @map("addon_type")
  price        Float           @default(0)
  isActive     Boolean         @default(true) @map("is_active")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")
  cartAddons   CartItemAddon[]
  combo        Combo?          @relation(fields: [comboId], references: [id], onDelete: Cascade)
  menuItem     MenuItem?       @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  restaurant   Restaurant      @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
  @@index([menuItemId])
  @@index([comboId])
  @@map("item_addons")
}

model Offer {
  mongoId         String            @id @default(auto()) @map("_id") @db.ObjectId
  id              Int               @unique @default(0)
  code            String?
  title           String
  description     String?
  discountType    String            @map("discount_type")
  discountValue   Float             @map("discount_value")
  minOrderAmount  Float             @default(0) @map("min_order_amount")
  maxDiscount     Float?            @map("max_discount")
  scope           String            @default("PLATFORM")
  usageLimit      Int?              @map("usage_limit")
  perUserLimit    Int?              @map("per_user_limit")
  startDate       DateTime?         @map("start_date")
  endDate         DateTime?         @map("end_date")
  isActive        Boolean           @default(true) @map("is_active")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  carts           Cart[]
  orders          Order[]
  restaurantLinks RestaurantOffer[]

  @@index([isActive, startDate, endDate])
  @@map("offers")
}

model RestaurantOffer {
  mongoId      String     @id @default(auto()) @map("_id") @db.ObjectId
  id           Int        @unique @default(0)
  restaurantId Int        @map("restaurant_id")
  offerId      Int        @map("offer_id")
  offer        Offer      @relation(fields: [offerId], references: [id], onDelete: Cascade)
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, offerId])
  @@index([offerId])
  @@map("restaurant_offers")
}

model Cart {
  mongoId        String     @id @default(auto()) @map("_id") @db.ObjectId
  id             Int        @unique @default(0)
  userId         Int        @map("user_id")
  restaurantId   Int        @map("restaurant_id")
  offerId        Int?       @map("offer_id")
  totalAmount    Float      @default(0) @map("total_amount")
  discountAmount Float      @default(0) @map("discount_amount")
  deliveryFee    Float      @default(0) @map("delivery_fee")
  taxAmount      Float      @default(0) @map("tax_amount")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")
  items          CartItem[]
  offer          Offer?     @relation(fields: [offerId], references: [id], onDelete: SetNull)
  restaurant     Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, restaurantId])
  @@index([restaurantId])
  @@map("carts")
}

model CartItem {
  mongoId             String          @id @default(auto()) @map("_id") @db.ObjectId
  id                  Int             @unique @default(0)
  cartId              Int             @map("cart_id")
  menuItemId          Int?            @map("menu_item_id")
  comboId             Int?            @map("combo_id")
  itemType            String          @default("MENU_ITEM") @map("item_type")
  itemSnapshot        String?         @map("item_snapshot")
  quantity            Int             @default(1)
  itemPrice           Float           @map("item_price")
  totalPrice          Float           @map("total_price")
  specialInstructions String?         @map("special_instructions")
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")
  addons              CartItemAddon[]
  cart                Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  combo               Combo?          @relation(fields: [comboId], references: [id], onDelete: Cascade)
  menuItem            MenuItem?       @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@index([cartId])
  @@index([menuItemId])
  @@index([comboId])
  @@map("cart_items")
}

model CartItemAddon {
  mongoId    String    @id @default(auto()) @map("_id") @db.ObjectId
  id         Int       @unique @default(0)
  cartItemId Int       @map("cart_item_id")
  addonId    Int       @map("addon_id")
  addonPrice Float     @map("addon_price")
  addon      ItemAddon @relation(fields: [addonId], references: [id], onDelete: Cascade)
  cartItem   CartItem  @relation(fields: [cartItemId], references: [id], onDelete: Cascade)

  @@unique([cartItemId, addonId])
  @@index([addonId])
  @@map("cart_item_addons")
}

model Order {
  mongoId                  String                    @id @default(auto()) @map("_id") @db.ObjectId
  id                       Int                       @unique @default(0)
  userId                   Int                       @map("user_id")
  restaurantId             Int                       @map("restaurant_id")
  addressId                Int                       @map("address_id")
  deliveryPartnerId        Int?                      @map("delivery_partner_id")
  offerId                  Int?                      @map("offer_id")
  orderNumber              String                    @unique @map("order_number")
  status                   String                    @default("PLACED")
  paymentStatus            String                    @default("PENDING") @map("payment_status")
  paymentMethod            String                    @default("COD") @map("payment_method")
  subtotal                 Float
  deliveryFee              Float                     @default(0) @map("delivery_fee")
  taxAmount                Float                     @default(0) @map("tax_amount")
  discountAmount           Float                     @default(0) @map("discount_amount")
  tipAmount                Float                     @default(0) @map("tip_amount")
  totalAmount              Float                     @map("total_amount")
  routeDistanceKm          Float?                    @map("route_distance_km")
  travelDurationMinutes    Int?                      @map("travel_duration_minutes")
  estimatedDeliveryMinutes Int?                      @map("estimated_delivery_minutes")
  trafficDelayMinutes      Int                       @default(0) @map("traffic_delay_minutes")
  weatherDelayMinutes      Int                       @default(0) @map("weather_delay_minutes")
  delayMinutes             Int                       @default(0) @map("delay_minutes")
  specialInstructions      String?                   @map("special_instructions")
  orderedAt                DateTime                  @default(now()) @map("ordered_at")
  confirmedAt              DateTime?                 @map("confirmed_at")
  acceptedAt               DateTime?                 @map("accepted_at")
  preparingAt              DateTime?                 @map("preparing_at")
  readyForPickupAt         DateTime?                 @map("ready_for_pickup_at")
  assignedAt               DateTime?                 @map("assigned_at")
  pickedUpAt               DateTime?                 @map("picked_up_at")
  onTheWayAt               DateTime?                 @map("on_the_way_at")
  outForDeliveryAt         DateTime?                 @map("out_for_delivery_at")
  delayedAt                DateTime?                 @map("delayed_at")
  deliveredAt              DateTime?                 @map("delivered_at")
  cancelledAt              DateTime?                 @map("cancelled_at")
  deletedAt                DateTime?                 @map("deleted_at")
  createdAt                DateTime                  @default(now()) @map("created_at")
  updatedAt                DateTime                  @updatedAt @map("updated_at")
  address                  Address                   @relation(fields: [addressId], references: [id], onDelete: Restrict)
  deliveryPartner          DeliveryPartner?          @relation(fields: [deliveryPartnerId], references: [id], onDelete: SetNull)
  items                    OrderItem[]
  offer                    Offer?                    @relation(fields: [offerId], references: [id], onDelete: SetNull)
  payments                 Payment[]
  restaurant               Restaurant                @relation(fields: [restaurantId], references: [id], onDelete: Restrict)
  review                   Review?
  statusEvents             OrderStatusEvent[]
  deliveryAssignmentOffers DeliveryAssignmentOffer[]
  user                     User                      @relation("CustomerOrders", fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId, status])
  @@index([restaurantId, status])
  @@index([deliveryPartnerId, status])
  @@index([orderedAt])
  @@index([deletedAt, status, createdAt])
  @@map("orders")
}

model OrderStatusEvent {
  mongoId   String   @id @default(auto()) @map("_id") @db.ObjectId
  id        Int      @unique @default(0)
  orderId   Int      @map("order_id")
  actorId   Int?     @map("actor_id")
  status    String
  note      String?
  latitude  Float?
  longitude Float?
  createdAt DateTime @default(now()) @map("created_at")
  actor     User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
  @@map("order_status_events")
}

model OrderItem {
  mongoId      String           @id @default(auto()) @map("_id") @db.ObjectId
  id           Int              @unique @default(0)
  orderId      Int              @map("order_id")
  menuItemId   Int?             @map("menu_item_id")
  comboId      Int?             @map("combo_id")
  itemType     String           @default("MENU_ITEM") @map("item_type")
  itemSnapshot String?          @map("item_snapshot")
  itemName     String           @map("item_name")
  itemPrice    Float            @map("item_price")
  quantity     Int              @default(1)
  totalPrice   Float            @map("total_price")
  foodType     String?          @map("food_type")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")
  addons       OrderItemAddon[]
  combo        Combo?           @relation(fields: [comboId], references: [id], onDelete: SetNull)
  menuItem     MenuItem?        @relation(fields: [menuItemId], references: [id], onDelete: Restrict)
  order        Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([menuItemId])
  @@index([comboId])
  @@map("order_items")
}

model OrderItemAddon {
  mongoId     String    @id @default(auto()) @map("_id") @db.ObjectId
  id          Int       @unique @default(0)
  orderItemId Int       @map("order_item_id")
  addonName   String    @map("addon_name")
  addonPrice  Float     @map("addon_price")
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@index([orderItemId])
  @@map("order_item_addons")
}

model Payment {
  mongoId        String    @id @default(auto()) @map("_id") @db.ObjectId
  id             Int       @unique @default(0)
  orderId        Int       @map("order_id")
  transactionId  String?   @map("transaction_id")
  paymentGateway String?   @map("payment_gateway")
  amount         Float
  status         String    @default("PENDING")
  paidAt         DateTime? @map("paid_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  order          Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("payments")
}

model SavedPaymentMethod {
  mongoId      String   @id @default(auto()) @map("_id") @db.ObjectId
  id           Int      @unique @default(0)
  userId       Int      @map("user_id")
  type         String
  label        String?
  holderName   String?  @map("holder_name")
  maskedEnding String?  @map("masked_ending")
  cardBrand    String?  @map("card_brand")
  expiryMonth  String?  @map("expiry_month")
  expiryYear   String?  @map("expiry_year")
  upiId        String?  @map("upi_id")
  isPrimary    Boolean  @default(false) @map("is_primary")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@index([userId, isPrimary])
  @@map("saved_payment_methods")
}

model DeliveryPartner {
  mongoId               String                    @id @default(auto()) @map("_id") @db.ObjectId
  id                    Int                       @unique @default(0)
  userId                Int                       @unique @map("user_id")
  vehicleType           String                    @map("vehicle_type")
  vehicleNumber         String?                   @map("vehicle_number")
  licenseNumber         String?                   @map("license_number")
  availabilityStatus    String                    @default("OFFLINE") @map("availability_status")
  currentLatitude       Float?                    @map("current_latitude")
  currentLongitude      Float?                    @map("current_longitude")
  lastLocationUpdatedAt DateTime?                 @map("last_location_updated_at")
  avgRating             Float                     @default(0) @map("avg_rating")
  totalDeliveries       Int                       @default(0) @map("total_deliveries")
  isVerified            Boolean                   @default(false) @map("is_verified")
  createdAt             DateTime                  @default(now()) @map("created_at")
  updatedAt             DateTime                  @updatedAt @map("updated_at")
  assignmentOffers      DeliveryAssignmentOffer[]
  documents             DeliveryDocument[]
  orders                Order[]
  user                  User                      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([availabilityStatus])
  @@index([availabilityStatus, isVerified, currentLatitude, currentLongitude])
  @@index([lastLocationUpdatedAt])
  @@map("delivery_partners")
}

model DeliveryAssignmentOffer {
  mongoId           String          @id @default(auto()) @map("_id") @db.ObjectId
  id                Int             @unique @default(0)
  orderId           Int             @map("order_id")
  deliveryPartnerId Int             @map("delivery_partner_id")
  batchNumber       Int             @default(1) @map("batch_number")
  status            String          @default("PENDING")
  radiusKm          Float           @map("radius_km")
  distanceKm        Float?          @map("distance_km")
  offeredAt         DateTime        @default(now()) @map("offered_at")
  expiresAt         DateTime        @map("expires_at")
  respondedAt       DateTime?       @map("responded_at")
  acceptedAt        DateTime?       @map("accepted_at")
  closedReason      String?         @map("closed_reason")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")
  deliveryPartner   DeliveryPartner @relation(fields: [deliveryPartnerId], references: [id], onDelete: Cascade)
  order             Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([orderId, deliveryPartnerId, batchNumber])
  @@index([orderId, status, expiresAt])
  @@index([deliveryPartnerId, status, expiresAt])
  @@index([status, expiresAt])
  @@map("delivery_assignment_offers")
}

model DeliveryDocument {
  mongoId           String          @id @default(auto()) @map("_id") @db.ObjectId
  id                Int             @unique @default(0)
  deliveryPartnerId Int             @map("delivery_partner_id")
  name              String
  fileUrl           String          @map("file_url")
  status            String          @default("PENDING")
  rejectionReason   String?         @map("rejection_reason")
  uploadedAt        DateTime        @default(now()) @map("uploaded_at")
  reviewedAt        DateTime?       @map("reviewed_at")
  deliveryPartner   DeliveryPartner @relation(fields: [deliveryPartnerId], references: [id], onDelete: Cascade)

  @@index([deliveryPartnerId])
  @@map("delivery_documents")
}

model Review {
  mongoId      String     @id @default(auto()) @map("_id") @db.ObjectId
  id           Int        @unique @default(0)
  userId       Int        @map("user_id")
  restaurantId Int        @map("restaurant_id")
  orderId      Int?       @unique @map("order_id")
  rating       Int
  reviewText   String?    @map("review_text")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  order        Order?     @relation(fields: [orderId], references: [id], onDelete: SetNull)
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([restaurantId, rating])
  @@index([userId])
  @@map("reviews")
}

model FavoriteRestaurant {
  mongoId      String     @id @default(auto()) @map("_id") @db.ObjectId
  id           Int        @unique @default(0)
  userId       Int        @map("user_id")
  restaurantId Int        @map("restaurant_id")
  createdAt    DateTime   @default(now()) @map("created_at")
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, restaurantId])
  @@index([restaurantId])
  @@map("favorite_restaurants")
}

model Notification {
  mongoId   String   @id @default(auto()) @map("_id") @db.ObjectId
  id        Int      @unique @default(0)
  userId    Int      @map("user_id")
  title     String
  message   String
  type      String
  meta      String?
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}

model Region {
  mongoId          String                 @id @default(auto()) @map("_id") @db.ObjectId
  id               Int                    @unique @default(0)
  name             String
  districtName     String                 @map("district_name")
  stateName        String                 @map("state_name")
  code             String                 @unique
  slug             String                 @unique
  notes            String?
  primaryPincode   String?                @map("primary_pincode")
  additionalPincodes String[]             @default([]) @map("additional_pincodes")
  isActive         Boolean                @default(true) @map("is_active")
  managerUserId    Int?                   @map("manager_user_id")
  createdAt        DateTime               @default(now()) @map("created_at")
  updatedAt        DateTime               @updatedAt @map("updated_at")
  approvalRequests ApprovalRequest[]
  manager          User?                  @relation("RegionManager", fields: [managerUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  operationsNotes  OperationsRegionNote[] @relation("RegionOperationsNotes")
  registrationApplications RegistrationApplication[]
  restaurants      Restaurant[]           @relation("RegionRestaurants")
  users            User[]                 @relation("RegionUsers")

  @@index([stateName, districtName])
  @@index([isActive])
  @@index([managerUserId])
  @@map("regions")
}

model OperationsRegionNote {
  mongoId     String   @id @default(auto()) @map("_id") @db.ObjectId
  id          Int      @unique @default(0)
  regionId    Int?     @map("region_id")
  state       String
  district    String?
  title       String
  message     String
  updatedById Int?     @map("updated_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  region      Region?  @relation("RegionOperationsNotes", fields: [regionId], references: [id], onDelete: SetNull)
  updatedBy   User?    @relation("OperationsNoteAuthor", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([regionId])
  @@index([state, district])
  @@index([updatedById])
  @@map("operations_region_notes")
}

model ApprovalRequest {
  mongoId          String   @id @default(auto()) @map("_id") @db.ObjectId
  id               Int      @unique @default(0)
  requesterId      Int      @map("requester_id")
  requesterRole    String   @map("requester_role")
  targetEntityType String   @map("target_entity_type")
  targetEntityId   Int      @map("target_entity_id")
  regionId         Int?     @map("region_id")
  actionType       String   @map("action_type")
  beforeSnapshot   String?  @map("before_snapshot")
  proposedChanges  String   @map("proposed_changes")
  status           String   @default("PENDING")
  reviewComment    String?  @map("review_comment")
  reviewedById     Int?     @map("reviewed_by_id")
  reviewedAt       DateTime? @map("reviewed_at")
  appliedAt        DateTime? @map("applied_at")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  region           Region?  @relation(fields: [regionId], references: [id], onDelete: SetNull)
  requester        User     @relation("ApprovalRequestRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  reviewedBy       User?    @relation("ApprovalRequestReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([requesterId, status])
  @@index([status, createdAt])
  @@index([regionId, status])
  @@index([targetEntityType, targetEntityId])
  @@map("approval_requests")
}

model RegistrationApplication {
  mongoId                 String   @id @default(auto()) @map("_id") @db.ObjectId
  id                      Int      @unique @default(0)
  roleType                String   @map("role_type")
  fullName                String   @map("full_name")
  email                   String
  phone                   String
  alternatePhone          String?  @map("alternate_phone")
  passwordHash            String   @map("password_hash")
  addressLine             String   @map("address_line")
  state                   String
  district                String
  pincode                 String
  regionId                Int?     @map("region_id")
  restaurantName          String?  @map("restaurant_name")
  restaurantAddress       String?  @map("restaurant_address")
  fssaiCertificateNumber  String?  @map("fssai_certificate_number")
  idProofType             String   @map("id_proof_type")
  idProofNumber           String   @map("id_proof_number")
  vehicleType             String?  @map("vehicle_type")
  vehicleNumber           String?  @map("vehicle_number")
  drivingLicenseNumber    String?  @map("driving_license_number")
  payoutDetails           String?  @map("payout_details")
  documents               String?  @map("documents")
  status                  String   @default("PENDING")
  assignedRegionalManagerId Int?   @map("assigned_regional_manager_id")
  reviewedById            Int?     @map("reviewed_by_id")
  approvedUserId          Int?     @map("approved_user_id")
  reviewRemarks           String?  @map("review_remarks")
  reviewedAt              DateTime? @map("reviewed_at")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")
  approvedUser            User?    @relation("RegistrationApplicationApprovedUser", fields: [approvedUserId], references: [id], onDelete: SetNull)
  assignedRegionalManager User?    @relation("RegistrationApplicationAssignee", fields: [assignedRegionalManagerId], references: [id], onDelete: SetNull)
  region                  Region?  @relation(fields: [regionId], references: [id], onDelete: SetNull)
  reviewedBy              User?    @relation("RegistrationApplicationReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([roleType, status])
  @@index([status, createdAt])
  @@index([regionId, status])
  @@index([assignedRegionalManagerId, status])
  @@index([email, status])
  @@map("registration_applications")
}

model Reservation {
  mongoId         String     @id @default(auto()) @map("_id") @db.ObjectId
  id              Int        @unique @default(0)
  userId          Int        @map("user_id")
  restaurantId    Int        @map("restaurant_id")
  reservationDate DateTime   @map("reservation_date")
  guests          Int
  slot            String
  specialRequest  String?    @map("special_request")
  contactPhone    String?    @map("contact_phone")
  status          String     @default("PENDING")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")
  restaurant      Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([restaurantId, reservationDate])
  @@index([userId, status])
  @@map("reservations")
}

model IdCounter {
  id        String   @id @map("_id")
  value     Int      @default(0)
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("id_counters")
}
